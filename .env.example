# =============================================================================
# Copy to `.env` or `.env.local` and fill in values.
# =============================================================================

# --- Ghost CMS (lib/env.ts; also next-sitemap.config.js) ---------------------
GHOST_CONTENT_API_URL=
GHOST_CONTENT_API_KEY=
GHOST_CONTENT_API_VERSION=v5.0
# Aliases (optional): BLOG_API, CONTENT_API_KEY

# --- Public ------------------------------------------------------------------
# Nest uses `/api/v1` — either form works (code normalizes):
#   http://localhost:5000
#   http://localhost:5000/api/v1
NEXT_PUBLIC_BACKEND_URL=http://localhost:5000/api/v1
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_GA_ID=

# --- Server ------------------------------------------------------------------
LOG_LEVEL=info

# --- NextAuth ----------------------------------------------------------------
AUTH_SECRET=
AUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional: restrict /admin to these emails (comma-separated)
# ADMIN_ALLOWED_EMAILS=
