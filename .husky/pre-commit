# Git GUIs / IDE commits often run hooks with a minimal PATH; restore Node/npm.
export NVM_DIR="${NVM_DIR:-$HOME/.nvm}"
[ -s "$NVM_DIR/nvm.sh" ] && . "$NVM_DIR/nvm.sh" 2>/dev/null || true
export PATH="/opt/homebrew/bin:/usr/local/bin:$PATH"

npm run format

npm run lint ||
(
  echo '😤🏀👋😤 Its not working properly! 😤🏀👋😤
        Linting failed. Make the required changes listed above, add changes and try to commit again.'
  false;
)

# If everything passes... Now we can commit
echo '
     ✅✅✅✅ You win this time... I am committing this now. ✅✅✅✅

     '
